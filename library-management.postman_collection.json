{
  "info": {
    "name": "Library Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "bookId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "loanId", "value": "" }
